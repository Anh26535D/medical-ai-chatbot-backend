# App configuration
PORT=8080
GIN_MODE=release

# Database connections
MONGODB_URI=mongodb://mongodb:27017
REDIS_ADDR=redis:6379

# MQTT Broker connection
MQTT_BROKER_URI=tcp://emqx:1883

# Firebase RTDB Integration (Production credentials)
FIREBASE_DATABASE_URL=https://your-firebase-project-default-rtdb.firebaseio.com/
# Path (inside the container) to the Firebase service account JSON used both for
# admin-level RTDB REST calls and for minting Firebase Auth custom tokens at login.
# Mounted via docker-compose.yml as ./firebase-adminsdk.json:/app/firebase-adminsdk.json:ro
FIREBASE_KEY_PATH=/app/firebase-adminsdk.json

# JWT authentication security secret
JWT_SECRET=your_jwt_secret_key_here

# Shared secret the backend's own MQTT worker uses to authenticate with EMQX
# (see internal/worker/mqtt_worker.go and MQTTWorkerClientID in internal/handler/auth.go)
MQTT_WORKER_SECRET=your_mqtt_worker_secret_here
